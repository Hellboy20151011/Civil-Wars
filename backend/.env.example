# Kopieren: Diese Datei nach .env kopieren und die Werte eintragen.
# Die .env-Datei niemals in die Versionskontrolle einchecken!

# Umgebung: development | production
NODE_ENV=development

# Server-Port (optional, Standard: 3000)
PORT=3000

# Session-Geheimschlüssel – in Production MUSS dieser Wert gesetzt sein!
SESSION_SECRET=civil-wars-super-secret

# Datenbankverbindung – in Production MÜSSEN alle Werte gesetzt sein
DB_USER=postgres
DB_HOST=localhost
DB_NAME=civil_wars
DB_PASSWORD=admin
DB_PORT=5433

# Tick-Dauer in Sekunden (optional, Standard: 30 – für Live-Betrieb z. B. 600)
TICK_DURATION_SECONDS=30
