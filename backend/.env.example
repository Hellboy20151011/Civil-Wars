# Kopiere diese Datei nach .env und trage deine Werte ein.
# Die .env-Datei niemals in die Versionskontrolle einchecken!

# Session-Geheimschlüssel – bitte durch einen langen, zufälligen Wert ersetzen
SESSION_SECRET=civil-wars-super-secret

# Datenbankverbindung
DB_USER=postgres
DB_HOST=localhost
DB_NAME=civil_wars
DB_PASSWORD=admin
DB_PORT=5433
