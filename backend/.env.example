# Kopieren: Diese Datei nach .env kopieren und die Werte eintragen.
# Die .env-Datei niemals in die Versionskontrolle einchecken!

# Umgebung: development | production
NODE_ENV=development

# Server-Port (optional, Standard: 3000)
PORT=3000

# Session-Geheimschlüssel – MUSS in allen Umgebungen gesetzt sein!
# Ohne diesen Wert wird beim Start ein zufälliger Schlüssel generiert (Sessions gehen bei Neustart verloren).
# Starken, zufälligen Wert nutzen, z. B.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ersetze-mich-durch-einen-starken-zufaelligen-wert

# Datenbankverbindung – DB_PASSWORD ist in ALLEN Umgebungen verpflichtend!
# Ohne DB_PASSWORD bricht der Server beim Start ab.
DB_USER=postgres
DB_HOST=localhost
DB_NAME=civil_wars
DB_PASSWORD=ersetze-mich-durch-dein-db-passwort
DB_PORT=5433

# Tick-Dauer in Sekunden (optional, Standard: 30 – für Live-Betrieb z. B. 600)
TICK_DURATION_SECONDS=30
